<mvc:View
    controllerName="com.wipro.earmms.itadmin.app.earmmsitadminapp.controller.Technicians"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" class="earmmsContentPage" enableScrolling="true">
        <content>
            <VBox class="earmmsPageContent">

                <!-- ── Page Header ── -->
                <HBox class="earmmsPageHeader mb1" alignItems="Center">
                    <VBox class="earmmsPageHeaderLeft">
                        <Title text="Technician Management" level="H3"/>
                        <Label text="Monitor workload, assignments, and performance of all technicians"/>
                    </VBox>
                    <ToolbarSpacer/>
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://group" color="#2563eb" size="1rem" class="mr05"/>
                        <Label text="Total Technicians:" class="textSmall mr05"/>
                        <Label text="{= ${/technicians}.length }" class="textBold textInfo"/>
                    </HBox>
                </HBox>

                <!-- ── Workload Summary (3 KPI cards) ── -->
                <HBox class="assetStatRow cols3 mb1">
                    <VBox class="assetStatCard statInfo" alignItems="Center" justifyContent="Center">
                        <Title text="{path: '/technicians', formatter: '.formatter.sumTechLoad'}" level="H2" class="textInfo"/>
                        <Label text="Total Active Tickets" class="textSmall textMuted"/>
                    </VBox>
                    <VBox class="assetStatCard statSuccess" alignItems="Center" justifyContent="Center">
                        <Title text="{path: '/technicians', formatter: '.formatter.sumTechCapacity'}" level="H2" class="textSuccess"/>
                        <Label text="Available Capacity" class="textSmall textMuted"/>
                    </VBox>
                    <VBox class="assetStatCard statWarning" alignItems="Center" justifyContent="Center">
                        <Title text="{path: '/technicians', formatter: '.formatter.avgTechUtilization'}" level="H2" class="textWarning"/>
                        <Label text="Avg. Utilization" class="textSmall textMuted"/>
                    </VBox>
                </HBox>

                <!-- ── Technician Cards ── -->
                <List
                    id="technicianList"
                    items="{/technicians}"
                    showSeparators="None"
                    noDataText="No technicians found">
                    <items>
                        <CustomListItem type="Active" press=".onTechPress">
                            <content>
                                <VBox class="techCard">

                                    <!-- Header: Avatar + Info + Workload -->
                                    <HBox class="techCardHeader">
                                        <Avatar
                                            initials="{path: 'name', formatter: '.formatter.techInitials'}"
                                            displayShape="Circle"
                                            size="L"
                                            backgroundColor="{path: 'name', formatter: '.formatter.techColor'}"
                                            class="mr1"/>

                                        <VBox class="techCardInfo">
                                            <HBox alignItems="Center" class="mb025">
                                                <Title text="{name}" level="H4" class="techCardName mr1"/>
                                                <ObjectStatus
                                                    text="{= ${currentLoad} >= ${maxLoad} ? 'Fully Loaded' : ${currentLoad} >= 3 ? 'High Load' : ${currentLoad} >= 1 ? 'Available' : 'Free' }"
                                                    state="{parts:[{path:'currentLoad'},{path:'maxLoad'}], formatter:'.formatter.loadToState'}"/>
                                            </HBox>
                                            <HBox class="techCardMeta" alignItems="Center" wrap="Wrap">
                                                <HBox class="techMetaChip" alignItems="Center">
                                                    <core:Icon src="sap-icon://wrench" size="0.75rem" color="#2563eb" class="mr025"/>
                                                    <Label text="{specialization}" class="textSmall textBold"/>
                                                </HBox>
                                                <HBox class="techMetaChip" alignItems="Center">
                                                    <core:Icon src="sap-icon://email" size="0.75rem" color="#6b7280" class="mr025"/>
                                                    <Label text="{email}" class="textSmall textMuted"/>
                                                </HBox>
                                                <HBox class="techMetaChip" alignItems="Center">
                                                    <core:Icon src="sap-icon://phone" size="0.75rem" color="#6b7280" class="mr025"/>
                                                    <Label text="{phone}" class="textSmall textMuted"/>
                                                </HBox>
                                            </HBox>
                                        </VBox>

                                        <ToolbarSpacer/>

                                        <VBox class="techCardWorkload" alignItems="End">
                                            <HBox alignItems="Center" class="mb025">
                                                <core:Icon src="sap-icon://activities" size="0.75rem" color="#64748b" class="mr025"/>
                                                <Label text="Workload" class="textSmall textBold textMuted"/>
                                            </HBox>
                                            <ProgressIndicator
                                                percentValue="{parts:[{path:'currentLoad'},{path:'maxLoad'}], formatter:'.formatter.loadToPercent'}"
                                                displayValue="{currentLoad}/{maxLoad} tickets"
                                                state="{parts:[{path:'currentLoad'},{path:'maxLoad'}], formatter:'.formatter.loadToState'}"
                                                class="techWorkloadBar"/>
                                        </VBox>
                                    </HBox>

                                    <!-- Footer: Assigned tickets summary -->
                                    <HBox class="techCardFooter" alignItems="Center">
                                        <core:Icon src="sap-icon://task" size="0.75rem" color="#64748b" class="mr05"/>
                                        <Label text="Assigned Tickets:" class="textSmall textBold mr05"/>
                                        <Label
                                            text="{parts: [{path: '/repairRequests'}, {path: 'technicianId'}], formatter: '.formatter.activeTicketsSummary'}"
                                            class="textSmall textMuted"/>
                                    </HBox>

                                </VBox>
                            </content>
                        </CustomListItem>
                    </items>
                </List>

            </VBox>
        </content>
    </Page>
</mvc:View>
